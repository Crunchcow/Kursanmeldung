# Vorlage für die .env-Datei – auf dem Server kopieren und ausfüllen:
# cp .env.example .env
#
# SECRET_KEY: Neuen Schlüssel generieren mit:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=hier-einen-neuen-sicheren-schluessel-eintragen
DEBUG=False
ALLOWED_HOSTS=89.167.0.28,deine-domain.de
CSRF_TRUSTED_ORIGINS=http://89.167.0.28,https://deine-domain.de

# E-Mail (Bestätigungsmail + Passwort-Reset)
# Lokal: console (gibt Mails im Terminal aus)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# Produktion: Microsoft 365 / Office 365
# Voraussetzung: SMTP AUTH muss im M365 Admin Center für dieses Postfach aktiviert sein
# https://admin.microsoft.com → Users → sportheim@ → Mail → Manage email apps → ✓ Authenticated SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=sportheim@westfalia-osterwick.de
EMAIL_HOST_PASSWORD=hier-das-passwort-eintragen
DEFAULT_FROM_EMAIL=sportheim@westfalia-osterwick.de
SITE_URL=http://89.167.0.28
