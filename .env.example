# Vorlage für die .env-Datei – auf dem Server kopieren und ausfüllen:
# cp .env.example .env
#
# SECRET_KEY: Neuen Schlüssel generieren mit:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=hier-einen-neuen-sicheren-schluessel-eintragen
DEBUG=False
ALLOWED_HOSTS=89.167.0.28,kursanmeldung.westfalia-osterwick.de
CSRF_TRUSTED_ORIGINS=https://kursanmeldung.westfalia-osterwick.de,http://89.167.0.28

# ───────────────────────────────────────────────────────────────────────────
# E-Mail-Backend – NUR EINE OPTION aktivieren
# ───────────────────────────────────────────────────────────────────────────

# Option A: Microsoft 365 / Office 365 via SMTP
# Voraussetzung: SMTP AUTH muss im M365 Admin Center für dieses Postfach aktiviert sein
# https://admin.microsoft.com → Users → sportheim@ → Mail → Manage email apps → ✓ Authenticated SMTP
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=sportheim@westfalia-osterwick.de
# EMAIL_HOST_PASSWORD=hier-das-passwort-eintragen

# Option B: Microsoft Graph API (App-only / client credentials – kein SMTP-Auth nötig)
# Voraussetzung: Azure App-Registrierung mit Graph API → Application permission → Mail.Send
EMAIL_BACKEND=kursanmeldung.graph_email_backend.GraphEmailBackend
MS_TENANT_ID=hier-azure-tenant-id-eintragen
MS_CLIENT_ID=hier-app-client-id-eintragen
MS_CLIENT_SECRET=hier-app-client-secret-eintragen
MS_SENDER=sportheim@westfalia-osterwick.de

# Lokal / Entwicklung (Mails im Terminal ausgeben, kein SMTP nötig):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

DEFAULT_FROM_EMAIL=sportheim@westfalia-osterwick.de
SITE_URL=https://kursanmeldung.westfalia-osterwick.de
